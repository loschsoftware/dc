<DassieConfig
    FormatVersion="1.0"
    IsDefinitionFile="true"
    SdkName="Core">

    <MacroDefinitions>
        <!-- Environment -->
        <Define Macro="Env" Parameters="[!VarName]" Trim="true">
            $(Eval: System.Environment.GetEnvironmentVariable ^^"$(@VarName)")
        </Define>

        <!-- Conditionals -->
        <Define Macro="If" Parameters="[!Condition, Then, Else]" Trim="true">
            $(Eval: ? $(@Condition) = { ^^"$(@Then)" } : = { ^^"$(@Else)" })
        </Define>

        <!-- Logic -->
        <Define Macro="And" Parameters="[!A, B]" Trim="true">
            $(If: $(@A), $(@B), false)
        </Define>

        <Define Macro="Or" Parameters="[!A, B]" Trim="true">
            $(If: $(@A), true, $(@B))
        </Define>

        <Define Macro="Not" Parameters="[!Value]" Trim="true">
            $(If: $(@Value), false, true)
        </Define>

        <!-- Numerics -->
        <Define Macro="Math.Add" Parameters="[!A, !B]" Trim="true">
            $(Eval: $(@A) + $(@B))
        </Define>

        <Define Macro="Math.Sub" Parameters="[!A, !B]" Trim="true">
            $(Eval: $(@A) - $(@B))
        </Define>

        <Define Macro="Math.Mul" Parameters="[!A, !B]" Trim="true">
            $(Eval: $(@A) * $(@B))
        </Define>

        <Define Macro="Math.Div" Parameters="[!A, !B]" Trim="true">
            $(Eval: $(@A) / $(@B))
        </Define>

        <!-- Strings -->
        <Define Macro="Str.Concat" Parameters="[A, B]" Trim="true">
            $(Eval: $(@A) + $(@B))
        </Define>

        <Define Macro="Str.Upper" Parameters="[Str]" Trim="true">
            $(Eval: ^^"$(@Str)".ToUpper)
        </Define>

        <Define Macro="Str.Lower" Parameters="[Str]" Trim="true">
            $(Eval: ^^"$(@Str)".ToLower)
        </Define>

        <Define Macro="Str.Trim" Parameters="[Str]" Trim="true">
            $(Eval: ^^"$(@Str)".Trim)
        </Define>

        <Define Macro="Str.Contains" Parameters="[Str, Value]" Trim="true">
            $(Eval: ^^"$(@Str)".Contains ^^"$(@Value)")s
        </Define>

        <!-- Paths -->
        <Define Macro="WorkingDir" Parameters="[]" Trim="true">
            $(Eval: System.IO.Directory.GetCurrentDirectory)
        </Define>

        <Define Macro="Path.FileName" Parameters="[!Path]" Trim="true">
            $(Eval: System.IO.Path.GetFileName ^^"$(@Path)")
        </Define>

        <Define Macro="Path.DirName" Parameters="[!Path]" Trim="true">
            $(Eval: System.IO.Path.GetDirectoryName ^^"$(@Path)")
        </Define>

        <Define Macro="Path.FileExtension" Parameters="[!Path]" Trim="true">
            $(Eval: System.IO.Path.GetExtension ^^"$(@Path)")
        </Define>

        <Define Macro="Path.ChangeExtension" Parameters="[!Path, !NewExtension]" Trim="true">
            $(Eval: System.IO.Path.ChangeExtension ^^"$(@Path)" ^^"$(@NewExtension)")
        </Define>

        <Define Macro="Path.Combine" Parameters="[!Path1, !Path2]" Trim="true">
            $(Eval: System.IO.Path.Combine ^^"$(@Path1)", ^^"$(@Path2)")
        </Define>

        <!-- Other -->
        <Define Macro="_Default" Parameters="[!Value, Default]" Trim="true">
            $(If: $(@Value) != (), $(@Value), $(@Default))
        </Define>
    </MacroDefinitions>
</DassieConfig>